generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  firebaseUid String?  @unique
  pushToken   String?  // FCM bildirimleri için
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tracks      Track[]
}

enum Role {
  USER
  ADMIN
}

model Product {
  id        String   @id @default(uuid())
  url       String   @unique
  name      String?
  brand     Brand
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tracks    Track[]
}

enum Brand {
  ZARA
  HM
  BERSHKA
  MANGO
  STRADIVARIUS
  TRENDYOL_MILLA
  OTHER
}

model Track {
  id        String   @id @default(uuid())
  userId    String
  productId String
  size      String   // Örn: "M", "38", "S"
  isActive  Boolean  @default(true) // Stok bulunduğunda veya kullanıcı iptal ettiğinde false olur
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  // Aynı kullanıcının aynı ürünün aynı bedenini birden fazla kez takip etmesini engeller
  @@unique([userId, productId, size]) 
}
